ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=

ARBITER_SQ_MODEL=nemotron-3-super-120b-a12b-free
ARBITER_AUX_MODEL=nemotron-3-super-120b-a12b-free
ARBITER_VISION_MODEL=
ARBITER_OUTPUT_DIR=./output
ARBITER_DB_PATH=./arbiter.db

ARBITER_PREFIX_TOKEN_BUDGET=4000
ARBITER_SUPPLEMENT_TOKEN_BUDGET=2000
ARBITER_METADATA_TOKEN_BUDGET=3000
ARBITER_SQ_MAX_TOKENS=2048
ARBITER_MAX_OUTCOMES=10
ARBITER_DOMAIN_TEXT_MIN_CHARS=500

ARBITER_RETRIEVAL_TOP_K=5
ARBITER_SMALL_SEGMENT_TOKEN_THRESHOLD=1500
ARBITER_LARGE_SEGMENT_CHAR_THRESHOLD=6000
ARBITER_RETRIEVAL_UNCERTAIN_THRESHOLD=0.35

ARBITER_SUPPLEMENT_PARSE_WINDOW=20
ARBITER_DOCTYPE_SCAN_PAGES=10
ARBITER_MIN_SEGMENTS=3
ARBITER_DOMAIN_TAG_SCAN_CHARS=300

ARBITER_QUOTE_VERIFY_THRESHOLD=85
ARBITER_QUOTE_MIN_VERIFY_CHARS=15
ARBITER_OUTCOME_MATCH_THRESHOLD=0.85

ARBITER_SCHEMA_REPAIR_MAX_RETRIES=2
ARBITER_NETWORK_MAX_RETRIES=3
ARBITER_MAX_ANNOTATIONS_PER_DOC=40
ARBITER_ANNOTATION_PREAMBLE_TOKENS=500

ARBITER_CONSORT_DETECT_THRESHOLD=0.80
ARBITER_CONSORT_ENABLED=false

ARBITER_MAX_CONCURRENCY=2
ARBITER_TRACE_LEVEL=full
ARBITER_REPORT_ENABLED=true
